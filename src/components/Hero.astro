---
import { STRINGS } from '../lib/i18n';
const en = STRINGS.en;
const base = import.meta.env.BASE_URL;
---
<section class="hero wrap" id="top">
  <p class="eyebrow" data-i18n="hero_eyebrow">{en.hero_eyebrow}</p>
  <h1 class="serif title">
    <span class="line1" data-i18n="hero_title_a">{en.hero_title_a}</span>
    <span class="line2" data-i18n="hero_title_b">{en.hero_title_b}</span>
  </h1>
  <p class="sub" data-i18n="hero_sub">{en.hero_sub}</p>
  <div class="cta">
    <a class="btn dl" href="#download" data-i18n="cta_download">{en.cta_download}</a>
  </div>
  <img
    class="shot heroshot"
    src={`${base}/shots/01-hero.png`}
    alt="Galley reviewing a pull request"
  />
</section>

<style>
  .hero {
    padding-top: 64px;
    text-align: center;
  }
  .eyebrow {
    margin-bottom: 26px;
  }
  .title {
    font-family: 'Spectral', serif;
    font-weight: 500;
    font-size: clamp(40px, 6vw, 68px);
    line-height: 1.04;
    letter-spacing: -0.01em;
    margin: 0;
  }
  .line1 {
    display: block;
  }
  .line2 {
    display: block;
    font-style: italic;
    font-weight: 400;
    color: var(--italic);
  }
  .sub {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 17px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 520px;
    margin: 26px auto 0;
  }
  .cta {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-top: 34px;
  }
  .dl {
    font-size: 15px;
    font-weight: 500;
    padding: 13px 26px;
    border-radius: 9px;
  }
  .heroshot {
    margin-top: 64px;
    border-radius: 14px;
  }
</style>
