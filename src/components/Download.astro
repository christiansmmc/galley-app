---
import { STRINGS } from '../lib/i18n';
const en = STRINGS.en;
---
<section class="download" id="download">
  <div class="inner">
    <p class="eyebrow" data-i18n="download_eyebrow">{en.download_eyebrow}</p>
    <h2 class="serif title" data-i18n="download_title">{en.download_title}</h2>
    <p class="sub" data-i18n="download_sub">{en.download_sub}</p>

    <div class="actions">
      <div id="dl-status" class="status mono" data-i18n="download_loading">{en.download_loading}</div>
      <div id="dl-buttons" class="buttons"></div>
      <a id="dl-releases" class="textlink releases" href="#" hidden data-i18n="download_releases_link">
        {en.download_releases_link}
      </a>
    </div>

    <div id="dl-meta" class="meta mono"></div>
  </div>
</section>

<style>
  .download {
    max-width: 1080px;
    margin: 0 auto;
    padding: 120px 32px;
    text-align: center;
  }
  .eyebrow {
    margin-bottom: 20px;
  }
  .title {
    font-family: 'Spectral', serif;
    font-weight: 500;
    font-size: clamp(34px, 4.5vw, 48px);
    letter-spacing: -0.01em;
    margin: 0;
  }
  .sub {
    font-family: 'IBM Plex Sans', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: var(--muted);
    max-width: 420px;
    margin: 18px auto 0;
  }
  .actions {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-top: 40px;
  }
  .status {
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--muted);
  }
  .status:empty {
    display: none;
  }
  .buttons {
    display: flex;
    gap: 12px;
    justify-content: center;
    flex-wrap: wrap;
  }
  .buttons:empty {
    display: none;
  }
  .buttons :global(.dlbtn) {
    font-size: 16px;
    font-weight: 600;
    padding: 16px 34px;
    border-radius: 10px;
  }
  .releases[hidden] {
    display: none;
  }
  .releases {
    font-size: 14px;
    font-weight: 500;
  }
  .meta {
    font-size: 11.5px;
    letter-spacing: 0.05em;
    color: var(--faint);
    margin-top: 28px;
  }
</style>

<script>
  import { buildDownloads } from '../lib/releases';
  import { STRINGS } from '../lib/i18n';

  const REPO = 'christiansmmc/galley-app';
  const API = `https://api.github.com/repos/${REPO}/releases/latest`;
  const RELEASES_URL = `https://github.com/${REPO}/releases`;

  const statusEl = document.getElementById('dl-status')!;
  const buttonsEl = document.getElementById('dl-buttons')!;
  const releasesEl = document.getElementById('dl-releases') as HTMLAnchorElement;
  const metaEl = document.getElementById('dl-meta')!;

  let state: 'loading' | 'none' | 'ready' = 'loading';

  function lang(): 'en' | 'pt' {
    const l = document.documentElement.getAttribute('lang');
    return l === 'pt' ? 'pt' : 'en';
  }
  function t(key: keyof (typeof STRINGS)['en']): string {
    return STRINGS[lang()][key];
  }

  function renderNone() {
    state = 'none';
    statusEl.textContent = t('download_none');
    buttonsEl.innerHTML = '';
    // Fall back to the releases page (allowed: not a repo-source link).
    releasesEl.href = RELEASES_URL;
    releasesEl.hidden = false;
    metaEl.textContent = '';
  }

  async function load() {
    try {
      const res = await fetch(API, { headers: { Accept: 'application/vnd.github+json' } });
      if (!res.ok) return renderNone();
      const data = await res.json();
      const downloads = buildDownloads(data);
      if (downloads.length === 0) return renderNone();
      state = 'ready';
      statusEl.textContent = '';
      // One button per available build (Windows / Linux .rpm / .deb): first is
      // primary, the rest ghost.
      buttonsEl.innerHTML = downloads
        .map((d, i) => {
          const variant = i === 0 ? 'btn-primary' : 'btn-ghost';
          return `<a class="btn ${variant} dlbtn" href="${d.url}">${d.label}</a>`;
        })
        .join('');
      releasesEl.href = RELEASES_URL;
      releasesEl.hidden = false;
      metaEl.dataset.version = data.tag_name;
      paintMeta();
    } catch (e) {
      renderNone();
    }
  }

  function paintMeta() {
    const v = metaEl.dataset.version;
    if (v) metaEl.textContent = `${t('download_version')} ${v} · ${t('footer_license')}`;
  }

  function applyLang() {
    if (state === 'none') {
      statusEl.textContent = t('download_none');
      return;
    }
    if (state === 'loading') statusEl.textContent = t('download_loading');
    paintMeta();
  }

  document.addEventListener('langchange', applyLang);
  load();
</script>
